# Optional split secrets file (more secure than keeping keys in .env)
# ─────────────────────────────────────────────────────────────────────────────
#   sudo mkdir -p /etc/gsbs-sync
#   sudo cp deploy/secrets.env.example /etc/gsbs-sync/env
#   sudo nano /etc/gsbs-sync/env
#   sudo chmod 600 /etc/gsbs-sync/env
#   sudo chown root:gsbs-sync /etc/gsbs-sync/env
#
# Then remove AWS_* lines from .env and run:
#   ENV_FILE=/etc/gsbs-sync/env ./bin/vps-sync run

AWS_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
