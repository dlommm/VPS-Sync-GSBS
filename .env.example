# VPS-Sync-GSBS configuration
# Copy to .env, replace every REPLACE_WITH_* value, then: chmod 600 .env
# Secrets can instead live in a separate file — see deploy/secrets.env.example.

# ── Paths ─────────────────────────────────────────────────────────────────────
GSBS_DB=/opt/vps-sync-gsbs/data/gsbs.db
OUT_DIR=/opt/vps-sync-gsbs/out

# ── Production DB seed (optional) ─────────────────────────────────────────────
# 1 = rsync gsbs.db from PROD_DB_SRC before each run; 0 = use the local copy
FETCH_PROD_DB=0
# user@host:/path/to/gsbs.db
PROD_DB_SRC=

# ── PCGW API sync ─────────────────────────────────────────────────────────────
RUN_PCGW_SYNC=1
# 0 = incremental (weekly, fast) | 1 = full re-crawl (first seed or repair only)
PCGW_SYNC_FULL=0

# ── Publish ───────────────────────────────────────────────────────────────────
# Every publish is a full bundle (GSBS servers merge it from any version).
# Public read URL written into index.json — must end with manifest/
PUBLIC_BASE=https://gsbs.ohhcloud.com/manifest/

# Version string embedded in exported bundles
GSBS_VERSION=vps-sync

# ── Cloudflare R2 (secrets — never commit .env) ───────────────────────────────
# Cloudflare → R2 → Manage R2 API tokens → Object Read & Write → gsbs bucket only
AWS_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
# Cloudflare dashboard → R2 → S3 API → copy account ID into endpoint URL
R2_ENDPOINT=https://REPLACE_WITH_CLOUDFLARE_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=gsbs
R2_PREFIX=manifest

# Prune old archive/v* snapshots in R2, keeping the newest R2_KEEP
R2_CLEANUP=1
R2_KEEP=24

# Weekly gzip'd database snapshot to the private db-backup/ R2 prefix.
# This DB is the only full PCGW mirror in the fleet — keep this on.
DB_BACKUP=1
DB_BACKUP_KEEP=6

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FILE=/opt/vps-sync-gsbs/logs/vps-sync.log
LOG_LEVEL=info
# Set 1 when running manually to also print logs to the terminal
LOG_MIRROR_STDERR=0

# ── Notifications (optional) ──────────────────────────────────────────────────
# Discord or Slack incoming-webhook URL; a message is posted after each
# run/bootstrap with the result and published manifest version.
# WEBHOOK_URL=
